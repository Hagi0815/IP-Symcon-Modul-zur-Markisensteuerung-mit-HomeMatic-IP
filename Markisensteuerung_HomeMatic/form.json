{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "Sensoren",
            "items": [
                {
                    "type": "SelectVariable",
                    "name": "RainSensorID",
                    "caption": "Regensensor (Boolean)",
                    "validVariableType": 0
                },
                {
                    "type": "SelectVariable",
                    "name": "WindSensorID",
                    "caption": "Windsensor (Float, km/h)",
                    "validVariableType": 2
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Zusatzsensor 1",
            "items": [
                {
                    "type": "Select",
                    "name": "ExtraSensor1Type",
                    "caption": "Typ",
                    "options": [
                        { "caption": "Deaktiviert",      "value": "off"         },
                        { "caption": "Temperatur (°C)",  "value": "temperature" },
                        { "caption": "Helligkeit (Lux)", "value": "brightness"  },
                        { "caption": "UV-Index",         "value": "uv"          }
                    ]
                },
                {
                    "type": "SelectVariable",
                    "name": "ExtraSensor1ID",
                    "caption": "Sensor-Variable"
                },
                {
                    "type": "NumberSpinner",
                    "name": "ExtraSensor1ThresholdDefault",
                    "caption": "Standard-Schwellwert (Einfahren ab)",
                    "minimum": 0,
                    "maximum": 100000
                },
                {
                    "type": "Label",
                    "caption": "Typ und Schwellwert können zusätzlich im WebFront geändert werden."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Zusatzsensor 2",
            "items": [
                {
                    "type": "Select",
                    "name": "ExtraSensor2Type",
                    "caption": "Typ",
                    "options": [
                        { "caption": "Deaktiviert",      "value": "off"         },
                        { "caption": "Temperatur (°C)",  "value": "temperature" },
                        { "caption": "Helligkeit (Lux)", "value": "brightness"  },
                        { "caption": "UV-Index",         "value": "uv"          }
                    ]
                },
                {
                    "type": "SelectVariable",
                    "name": "ExtraSensor2ID",
                    "caption": "Sensor-Variable"
                },
                {
                    "type": "NumberSpinner",
                    "name": "ExtraSensor2ThresholdDefault",
                    "caption": "Standard-Schwellwert (Einfahren ab)",
                    "minimum": 0,
                    "maximum": 100000
                },
                {
                    "type": "Label",
                    "caption": "Typ und Schwellwert können zusätzlich im WebFront geändert werden."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Aktor",
            "items": [
                {
                    "type": "SelectVariable",
                    "name": "ActorID",
                    "caption": "Aktor (HmIP-BROLL / HmIP-FROLL)"
                },
                {
                    "type": "Select",
                    "name": "ActorType",
                    "caption": "Aktor-Typ",
                    "options": [
                        { "caption": "Level (Float 0.0–1.0)", "value": "level" },
                        { "caption": "Boolean (An/Aus)",       "value": "bool"  }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Zeitfenster (Standardwerte)",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "StartMinDefault",
                    "caption": "Standard-Ausfahrzeit (Minuten seit 00:00)",
                    "minimum": 0,
                    "maximum": 1425,
                    "suffix": " min"
                },
                {
                    "type": "NumberSpinner",
                    "name": "EndMinDefault",
                    "caption": "Standard-Einfahrzeit (Minuten seit 00:00)",
                    "minimum": 0,
                    "maximum": 1425,
                    "suffix": " min"
                },
                {
                    "type": "Label",
                    "caption": "Beispiele: 480 = 08:00 Uhr, 1200 = 20:00 Uhr. Im WebFront viertelstündlich wählbar."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Windgrenze (Standardwert)",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "WindThresholdDefault",
                    "caption": "Standard-Windgrenze (km/h)",
                    "minimum": 0,
                    "maximum": 200,
                    "suffix": " km/h"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Jetzt prüfen",
            "onClick": "IPS_RequestAction($id, 'Check', '');"
        }
    ],
    "status": [
        { "code": 102, "icon": "active",   "caption": "Aktiv"   },
        { "code": 104, "icon": "inactive", "caption": "Inaktiv" }
    ]
}
